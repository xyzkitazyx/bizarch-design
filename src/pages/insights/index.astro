---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="インサイト">
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-medium tracking-widest text-electric-blue uppercase mb-4">Insights</p>
        <h1 class="text-4xl sm:text-5xl font-bold">インサイト</h1>
        <p class="mt-6 text-lg text-gray-500 max-w-2xl mx-auto">
          ビジネスアーキテクチャとAIに関する最新の知見をお届けします。
        </p>
      </div>
      <!-- Blog posts from microCMS will be rendered here -->
    </div>
  </section>
</Layout>
